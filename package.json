{
  "name": "trailhead-backend",
  "version": "0.1.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "npx ts-node src/index.ts",
    "dev": "tsc-watch --onSuccess \"node build/src/index.js\"",
    "compile": "tsc --build",
    "lint": "npx eslint src/* test/*.ts",
    "test": "NODE_ENV=test jest",
    "db:migrate": "npx sequelize-cli db:migrate --debug",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo --debug",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all --debug",
    "db:migration:generate": "sequelize migration:create"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/hapi": "^21.3.10",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "@sequelize/sqlite3": "^7.0.0-alpha.41",
    "better-sqlite3": "^12.11.0",
    "cors": "^2.8.5",
    "decomment": "^0.9.5",
    "dotenv": "^16.4.5",
    "hapi-auth-jwt2": "^10.6.0",
    "hapi-swagger": "^17.3.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jwks-rsa": "^3.1.0",
    "lodash": "^4.17.21",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.3",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^5.1.7",
    "typescript": "^5.5.4",
    "typescript-json-schema": "^0.65.1"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-js": "^2.7.2",
    "@types/decomment": "^0.9.5",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.3.3",
    "sequelize-cli": "^6.6.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  }
}
